# ============================================================
#  Copie ce fichier en ".env" (dans design-app/) et remplis-le.
#  Ne JAMAIS committer le .env réel.
# ============================================================

# --- Base de données Postgres (mot de passe fort, généré aléatoirement)
#  Génère-le par ex. avec :  openssl rand -base64 24
POSTGRES_PASSWORD=change_moi_mot_de_passe_db

# --- Compte administrateur (accès à la liste des projets)
ADMIN_USER=nina

# Hash bcrypt du mot de passe admin (PAS le mot de passe en clair !)
#  Génère-le avec :
#    docker compose run --rm design-app node scripts/hash-password.js 'TonMotDePasse'
#  puis colle la ligne $2a$... ci-dessous.
ADMIN_PASSWORD_HASH=$2a$12$REMPLACE_MOI_PAR_LE_HASH_BCRYPT

# --- Secret de signature des sessions (chaîne aléatoire longue)
#  Génère-le par ex. avec :  openssl rand -hex 32
SESSION_SECRET=change_moi_secret_session_aleatoire
